{
  "template_name": "laravel",
  "template_type": "overlay",
  "base_template": "universal-base",
  "compatible_overlays": [
    "monorepo",
    "scheduler"
  ],
  "capabilities": {
    "provides": [
      "web-framework",
      "php-runtime",
      "laravel-framework",
      "laravel-native-scheduler-surface"
    ],
    "requires": [
      "runtime-environment"
    ],
    "conflicts": [
      "worker-runtime"
    ],
    "composition_role": "framework"
  },
  "required_surfaces": [
    "app",
    "bootstrap",
    "routes",
    "config"
  ],
  "optional_surfaces": [
    "resources",
    "database"
  ],
  "governance_compatibility": "required",
  "maturity": "canonical",
  "supported_runtime_shapes": [
    "application",
    "service"
  ],
  "composition_overrides": {
    "scheduler": {
      "type": "laravel-native-scheduler-contract",
      "overlay": "laravel",
      "scheduler_surface": "app/Console/Kernel.php",
      "scheduler_contract": "framework-native",
      "required_surfaces": [
        "app",
        "bootstrap",
        "routes",
        "config",
        "app/Console/Kernel.php",
        "app/Console/Commands",
        "routes/console.php",
        "config/scheduler.php"
      ],
      "optional_surfaces": [
        "app/Jobs",
        "storage/logs"
      ]
    },
    "monorepo": {
      "type": "laravel-application",
      "overlay": "laravel",
      "placement": "apps/backend/laravel-app",
      "repository_structure": "monorepo",
      "required_surfaces": [
        "apps/backend/laravel-app/composer.json",
        "apps/backend/laravel-app/bootstrap/app.php",
        "apps/backend/laravel-app/config/app.php",
        "apps/backend/laravel-app/routes/web.php",
        "apps/backend/laravel-app/public/index.php",
        "apps/backend/laravel-app/app/Console",
        "apps/backend/laravel-app/app/Http"
      ],
      "optional_surfaces": [
        "apps/backend/laravel-app/resources",
        "apps/backend/laravel-app/database"
      ]
    }
  },
  "template_root": "docs/codex/templates/overlays/laravel",
  "description": "Laravel runtime overlay for the universal base scaffold."
}
